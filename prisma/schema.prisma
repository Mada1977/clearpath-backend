// ClearPath — Prisma Schema
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  self
  friend
  professional
}

enum Stage {
  curious
  cutting
  quitting
  recovering
  relapsed
}

enum Addiction {
  smoking
  alcohol
  drugs
  gambling
  pornography
  gaming
  social_media
  shopping
}

enum LogType {
  used
  resisted
  craving_sos
}

enum Trigger {
  stress
  boredom
  social
  emotional
  habit
  celebration
  physical
  seeing_others
  unknown
}

enum Mood {
  rough
  okay
  good
  great
}

enum Outcome {
  resisted
  gave_in
}

enum MessageRole {
  user
  assistant
}

model User {
  id          String     @id @default(uuid())
  email       String     @unique
  password    String     // bcrypt hash
  name        String?
  role        Role       @default(self)
  addictions  Addiction[]
  stage       Stage      @default(curious)
  dailyGoal   Int        @default(10) @map("daily_goal")
  isPremium   Boolean    @default(false) @map("is_premium")
  ageVerified Boolean    @default(false) @map("age_verified")
  locale      String     @default("fr-FR")
  resetToken     String?    @map("reset_token")
  resetExpiry    DateTime?  @map("reset_expiry")
  expoPushToken  String?    @map("expo_push_token")
  lastActiveAt   DateTime?  @map("last_active_at")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  logs        Log[]
  messages    AiMessage[]
  trackers    AddictionTracker[]

  @@map("users")
}

model AddictionTracker {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  category  Addiction
  name      String?
  startDate DateTime  @map("start_date")
  isActive  Boolean   @default(true) @map("is_active")
  isPaused  Boolean   @default(false) @map("is_paused")
  pausedAt  DateTime? @map("paused_at")
  notes     String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("addiction_trackers")
}

model Log {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  type       LogType
  addiction  Addiction
  trigger    Trigger   @default(unknown)
  intensity  Int?      // 1-4
  mood       Mood?
  outcome    Outcome?
  notes      String?
  loggedAt   DateTime  @default(now()) @map("logged_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, loggedAt])
  @@map("logs")
}

model AiMessage {
  id            String      @id @default(uuid())
  userId        String      @map("user_id")
  role          MessageRole
  content       String      // stored encrypted
  crisisFlagged Boolean     @default(false) @map("crisis_flagged")
  tokensUsed    Int?        @map("tokens_used")
  createdAt     DateTime    @default(now()) @map("created_at")

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
  @@map("ai_messages")
}
