# ─── Server ───────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database (PostgreSQL) ────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://clearpath:yourpassword@localhost:5432/clearpath_db"

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET="replace-with-a-long-random-secret-at-least-64-chars"
JWT_REFRESH_SECRET="replace-with-another-long-random-secret-64-chars"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="30d"

# ─── Anthropic Claude API ────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-your-key-here"
AI_MODEL="claude-sonnet-4-20250514"
AI_FREE_DAILY_LIMIT=20

# ─── Redis (for BullMQ job queues) ───────────────────────
REDIS_URL="redis://localhost:6379"

# ─── CORS ────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS="http://localhost:3000,https://clearpath.app"

# ─── Encryption ──────────────────────────────────────────
# 32-char key for AES-256 field-level encryption
ENCRYPTION_KEY="replace-with-32-char-encryption-key!!"

# ─── Email (Resend) ──────────────────────────────────────
RESEND_API_KEY="re_your_api_key_here"

# ─── Frontend URL (for password reset links) ─────────────
FRONTEND_URL="https://clearpath.app"

# ─── Admin ───────────────────────────────────────────────
# Secret token for GET /v1/admin/users — send as x-admin-token header
ADMIN_SECRET_TOKEN="replace-with-a-long-random-admin-token"
